{
  "name": "@ido_kawaz/server-framework",
  "version": "1.0.0",
  "description": "Server framework library for Kawaz Plus services",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run clean && tsc",
    "build:watch": "tsc --watch",
    "build:advanced": "npm run clean:advanced && npm i && tsc",
    "test": "npm run build && jest --runInBand",
    "test:advanced": "npm run build:advanced && jest --runInBand",
    "clean": "rimraf dist",
    "clean:advanced": "rimraf dist node_modules package-lock.json",
    "package": "npm run test:advanced && npm publish --access public"
  },
  "keywords": [
    "server",
    "express",
    "http"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/ramda": "^0.31.1",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "http-status-codes": "^2.3.0",
    "pino": "^10.3.1",
    "ramda": "^0.32.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.3",
    "jest": "^30.1.3",
    "rimraf": "^6.0.0",
    "ts-jest": "^29.4.1",
    "typescript": "^5.9.3"
  }
}
